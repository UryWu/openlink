{
  "manifest_version": 3,
  "name": "OpenLink",
  "version": "1.2.0",
  "description": "OpenLink 代理 — 拦截 AI 工具调用并转发至本地 FastAPI 后端",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:*/*"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "OpenLink",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.gemini.google.com/*",
        "*://aistudio.google.com/*",
        "*://*.chatgpt.com/*",
        "*://*.grok.com/*",
        "*://*.x.com/*",
        "*://*.kimi.com/*",
        "*://*.chat.mistral.ai/*",
        "*://*.perplexity.ai/*",
        "*://*.openrouter.ai/*",
        "*://*.qwen.ai/*",
        "*://*.t3.chat/*",
        "*://*.github.com/*",
        "*://*.z.ai/*",
        "*://*.arena.ai/*",
        "*://*.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "*://*.gemini.google.com/*",
        "*://aistudio.google.com/*",
        "*://*.chatgpt.com/*",
        "*://*.grok.com/*",
        "*://*.x.com/*",
        "*://*.kimi.com/*",
        "*://*.chat.mistral.ai/*",
        "*://*.perplexity.ai/*",
        "*://*.openrouter.ai/*",
        "*://*.qwen.ai/*",
        "*://*.t3.chat/*",
        "*://*.github.com/*",
        "*://*.z.ai/*",
        "*://*.arena.ai/*",
        "*://*.deepseek.com/*"
      ]
    }
  ]
}
